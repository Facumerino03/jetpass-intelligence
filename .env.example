APP_NAME=jetpass-intelligence
ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@<db_host>:5432/<db_name>
REDIS_URL=redis://localhost:6379/0
NOTAM_CACHE_TTL_HOURS=4
NOTAM_LOCATION_SYNC_ENABLED=true
NOTAM_LOCATION_SYNC_INTERVAL_HOURS=12
NOTAM_LOCATION_SYNC_ON_STARTUP=true
NOTAM_LOCATION_SYNC_HEADLESS=true
OPENROUTER_API_KEY=sk-or-v1-<your-openrouter-api-key>
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.0
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
GROQ_API_KEY=gsk_<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_API_KEY=nvapi-<your-nvidia-api-key>
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
GOOGLE_AI_STUDIO_API_KEY=<your-google-ai-studio-api-key>
GOOGLE_AI_STUDIO_MODEL=gemini-2.0-flash

# Vertex AI / Agent Platform OpenAPI (OAuth2: gcloud auth application-default login o service account JSON)
# Gemini (global): GOOGLE_VERTEX_LOCATION=global
# Llama MaaS (regional): usar la region del modelo, p. ej. us-central1 — ver documentacion del modelo
GOOGLE_VERTEX_PROJECT_ID=<your-gcp-project-id>
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=meta/llama-3.3-70b-instruct-maas
GOOGLE_VERTEX_CREDENTIALS_FILE=/path/to/service-account.json
